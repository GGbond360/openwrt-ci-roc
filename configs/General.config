########################################
# 基础
########################################
CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y

########################################
# NSS（开启）
########################################
CONFIG_FEED_nss_packages=y
CONFIG_FEED_sqm_scripts_nss=y

CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_nss-dp=y

CONFIG_PACKAGE_kmod-qca-nss-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-bridge=y

CONFIG_PACKAGE_luci-app-nss-ecm=y

########################################
# USB
########################################
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-xhci=y

########################################
# 文件系统
########################################
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-exfat=y

########################################
# Samba
########################################
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-client=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y

########################################
# WebDAV
########################################
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_uhttpd-mod-lua=y
CONFIG_PACKAGE_luci-app-webdav=y
CONFIG_PACKAGE_luci-i18n-webdav-zh-cn=y

########################################
# FTP（禁用）
########################################
CONFIG_PACKAGE_vsftpd=n
CONFIG_PACKAGE_proftpd=n
CONFIG_PACKAGE_luci-app-ftp=n

########################################
# Tailscale（含 LuCI）
########################################
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_luci-app-tailscale=y

# 必备内核
CONFIG_PACKAGE_kmod-tun=y

# 连接稳定性
CONFIG_PACKAGE_kmod-nf-conntrack=y

########################################
# 网络基础（nftables体系）
########################################
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ca-certificates=y

# fw4（nftables）
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y

# iptables 兼容层（建议保留，某些插件会用）
CONFIG_PACKAGE_iptables-nft=y

########################################
# 常用工具
########################################
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_btop=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_tune2fs=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_mmc-utils=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_acme-acmesh-dnsapi=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y

########################################
# LuCI
########################################
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-diskman=y

########################################
# IPv6 / 多拨（关闭）
########################################
CONFIG_PACKAGE_kmod-ip6tables=n
CONFIG_PACKAGE_ip6tables=n
CONFIG_PACKAGE_ip6tables-extra=n
CONFIG_PACKAGE_mwan3=n
CONFIG_PACKAGE_luci-app-mwan3=n
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=n

########################################
# NFS（关闭）
########################################
CONFIG_PACKAGE_kmod-fs-nfs=n
CONFIG_PACKAGE_kmod-fs-nfs-v4=n
CONFIG_PACKAGE_kmod-fs-nfsd=n
CONFIG_PACKAGE_luci-app-nfs=n
CONFIG_PACKAGE_luci-i18n-nfs-zh-cn=n
